#[builtin]
struct Unit {}

#[builtin]
type Runtime

#[builtin]
type I64

#[builtin]
fn print_i64(value: I64, runtime: Runtime)

fn main(runtime: Runtime) {
    print_i64(5, runtime)

    let variable = 6
    print_i64(variable, runtime)

    struct Foo {
        member: I64,
    }

    let x = Foo {
        member: 5,
    }
    Foo { member: let value } = x
    print_i64(value, runtime)
}
